[transport-udp]
type=transport
protocol=udp
bind=0.0.0.0

[transport-wss]
type=transport
protocol=wss
bind=0.0.0.0
; Fase 2: necessário para WebRTC.

[vonex-flux-trunk]
type=endpoint
transport=transport-udp
context=axion-voice-inbound
disallow=all
allow=alaw,ulaw
aors=vonex-flux-trunk-aor
outbound_auth=vonex-flux-trunk-auth
from_domain=SIP_TRUNK_HOST
direct_media=no
rtp_symmetric=yes
force_rport=yes
rewrite_contact=yes

[vonex-flux-trunk-auth]
type=auth
auth_type=userpass
username=SIP_TRUNK_USERNAME
password=SIP_TRUNK_PASSWORD

[vonex-flux-trunk-aor]
type=aor
contact=sip:SIP_TRUNK_HOST
qualify_frequency=60

[vonex-flux-trunk-identify]
type=identify
endpoint=vonex-flux-trunk
match=SIP_TRUNK_HOST

[1001]
type=endpoint
transport=transport-udp
context=axion-voice-internal
disallow=all
allow=alaw,ulaw
auth=1001-auth
aors=1001
callerid=Comercial 1 <1001>

[1001-auth]
type=auth
auth_type=userpass
username=1001
password=CHANGE_ME_1001

[1001]
type=aor
max_contacts=1

[webrtc-template](!)
type=endpoint
transport=transport-wss
context=axion-voice-internal
disallow=all
allow=opus,ulaw,alaw
webrtc=yes
use_avpf=yes
media_encryption=dtls
dtls_auto_generate_cert=yes
ice_support=yes
rtcp_mux=yes
rewrite_contact=yes
force_rport=yes
rtp_symmetric=yes
